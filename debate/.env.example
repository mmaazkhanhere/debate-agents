OPENAI_API_KEY=your_key_here
REDIS_HOST=localhost
REDIS_PORT=6379
DEBATE_CACHE_ENABLED=true
DEBATE_CACHE_TTL_SECONDS=1800
DEBATE_LOCK_TTL_SECONDS=240
DEBATER_1_MODEL=groq/llama-3.1-8b-instant
DEBATER_2_MODEL=groq/qwen/qwen3-32b
JUDGE_MODEL=groq/llama-3.3-70b-versatile
PRESENTER_MODEL=groq/openai/gpt-oss-120b
SUMMARY_MODEL=groq/openai/gpt-oss-120b
INTRO_SLEEP_SEC=10
TURN_SLEEP_SEC=18
CONCLUDE_SLEEP_SEC=0
JUDGE_SLEEP_SEC=0
CACHE_LOCK_CHECK_ATTEMPTS=2
CACHE_LOCK_CHECK_SLEEP_SECONDS=0.3
STREAM_IDLE_SLEEP_SECONDS=0
REDIS_STREAM_READ_COUNT=1
REDIS_STREAM_BLOCK_MS=10000
SQLITE_CONNECT_TIMEOUT_SECONDS=5
SQLITE_BUSY_TIMEOUT_MS=5000
# Pricing map for cost calculation. Values are USD per 1M tokens.
PRICING_JSON='{"groq/llama-3.1-8b-instant":{"input_per_million":0.2,"output_per_million":0.2}}'
